# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Gold API (optional — free tier, 6 requests/day from goldapi.io)
GOLD_API_KEY=

# Metals.dev API (optional — free tier, 50 requests/month)
METALS_DEV_API_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_DIAMOND_REPORT=price_...
STRIPE_PRICE_GOLD_REPORT=price_...
STRIPE_PRICE_RETAILER_REPORT=price_...
STRIPE_PRICE_ANNUAL_MEMBERSHIP=price_...

# Vercel Cron Jobs (set in Vercel dashboard → Settings → Environment Variables)
CRON_SECRET=

# Apify (for running scrapers)
APIFY_API_TOKEN=
